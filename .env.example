# DockerVerse Environment Configuration — EXAMPLE
# Copy this file to .env and fill in real values.
# .env is in .gitignore and must NEVER be committed to git.

# Docker hosts (pipe-separated)
# Format: id:name:address:local/remote
# Use port 2376 (TLS) for remote Docker daemons — never 2375 (unencrypted).
DOCKER_HOSTS=raspi1:Raspberry Main:unix:///var/run/docker.sock:local|raspi2:Raspberry Secondary:tcp://YOUR_HOST_IP:2376:remote

# Watchtower integration
WATCHTOWER_TOKEN=your-watchtower-token-here
WATCHTOWER_URLS=raspi1:http://172.26.0.1:8080|raspi2:http://YOUR_HOST_IP:8081

# Security — generate with: openssl rand -base64 48
JWT_SECRET=

# Admin credentials — set a strong password before first run
ADMIN_USER=admin
ADMIN_PASS=

# Email (SMTP2Go) — get your API key from https://app.smtp2go.com/settings/apikeys
SMTP2GO_API_KEY=

# Frontend
ORIGIN=http://localhost:3007
TZ=America/Mexico_City

# SSH configuration for host console
SSH_USER=pi
SSH_PORT=22
SSH_KEY_PATH=/data/ssh/id_rsa
SSH_KEY_PASSPHRASE=
